{
  "info": {
    "_postman_id": "kaizen-backend-routes-v1",
    "name": "Kaizen Backend Routes",
    "description": "Generated directly from backend route files. Use LOCAL or PROD environment with HOST_URL.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "accessToken", "value": "" },
    { "key": "username", "value": "demo_user" },
    { "key": "password", "value": "TestPass1a" },
    { "key": "newPassword", "value": "NewPass1a" },
    { "key": "githubApiKey", "value": "ghp_xxx" },
    { "key": "ensName", "value": "demo-agent.eth" },
    { "key": "repoId", "value": "" },
    { "key": "branchName", "value": "feature/demo" },
    { "key": "issueId", "value": "" },
    { "key": "prId", "value": "" },
    { "key": "commitId", "value": "" },
    { "key": "gitJobId", "value": "" },
    { "key": "githubOwner", "value": "owner" },
    { "key": "githubRepo", "value": "repo" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const host = pm.environment.get(\"HOST_URL\");",
          "if (!host) console.warn(\"Select LOCAL or PROD environment (HOST_URL).\");"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        { "name": "GET /health", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/health", "host": ["{{HOST_URL}}"], "path": ["health"] } } },
        { "name": "GET /status", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/status", "host": ["{{HOST_URL}}"], "path": ["status"] } } }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{HOST_URL}}/auth/register", "host": ["{{HOST_URL}}"], "path": ["auth", "register"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{HOST_URL}}/auth/login", "host": ["{{HOST_URL}}"], "path": ["auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}", "options": { "raw": { "language": "json" } } }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  try { const j = pm.response.json(); if (j.token) pm.collectionVariables.set(\"accessToken\", j.token); } catch(e) {}",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /auth/me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{HOST_URL}}/auth/me", "host": ["{{HOST_URL}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "PATCH /auth/github-api-key",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/auth/github-api-key", "host": ["{{HOST_URL}}"], "path": ["auth", "github-api-key"] },
            "body": { "mode": "raw", "raw": "{\n  \"github_api_key\": \"{{githubApiKey}}\"\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "POST /auth/change-password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/auth/change-password", "host": ["{{HOST_URL}}"], "path": ["auth", "change-password"] },
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"{{password}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}", "options": { "raw": { "language": "json" } } }
          }
        }
      ]
    },
    {
      "name": "Agents",
      "item": [
        {
          "name": "POST /agents",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/agents", "host": ["{{HOST_URL}}"], "path": ["agents"] },
            "body": { "mode": "raw", "raw": "{\n  \"ens_name\": \"{{ensName}}\",\n  \"role\": \"agent\",\n  \"capabilities\": [\"coding\"]\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        { "name": "GET /agents", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/agents", "host": ["{{HOST_URL}}"], "path": ["agents"] } } },
        { "name": "GET /agents/:ens_name", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/agents/{{ensName}}", "host": ["{{HOST_URL}}"], "path": ["agents", "{{ensName}}"] } } },
        {
          "name": "POST /agents/:ens_name/deposit",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/agents/{{ensName}}/deposit", "host": ["{{HOST_URL}}"], "path": ["agents", "{{ensName}}", "deposit"] },
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 100,\n  \"note\": \"seed\"\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        { "name": "GET /agents/:ens_name/wallet", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/agents/{{ensName}}/wallet", "host": ["{{HOST_URL}}"], "path": ["agents", "{{ensName}}", "wallet"] } } },
        {
          "name": "PATCH /agents/:ens_name/wallet",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/agents/{{ensName}}/wallet", "host": ["{{HOST_URL}}"], "path": ["agents", "{{ensName}}", "wallet"] },
            "body": { "mode": "raw", "raw": "{\n  \"spending_cap\": 250\n}", "options": { "raw": { "language": "json" } } }
          }
        }
      ]
    },
    {
      "name": "Repositories",
      "item": [
        {
          "name": "POST /repositories",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/repositories", "host": ["{{HOST_URL}}"], "path": ["repositories"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"demo-repo\",\n  \"owner_ens\": \"{{ensName}}\",\n  \"description\": \"demo\",\n  \"repo_type\": \"general\"\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "POST /repositories/import-from-github",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/repositories/import-from-github", "host": ["{{HOST_URL}}"], "path": ["repositories", "import-from-github"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"owner_ens\": \"{{ensName}}\",\n  \"github_owner\": \"{{githubOwner}}\",\n  \"github_repo\": \"{{githubRepo}}\",\n  \"github_default_branch\": \"main\",\n  \"name\": \"{{githubRepo}}\",\n  \"repo_type\": \"general\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Creates Kaizen repo, links GitHub, provisions PR webhook. Server needs GITHUB_WEBHOOK_SECRET + GITHUB_WEBHOOK_CALLBACK_URL. Only supported webhook path."
          }
        },
        { "name": "GET /repositories", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories", "host": ["{{HOST_URL}}"], "path": ["repositories"] } } },
        { "name": "GET /repositories/:id", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}"] } } },
        {
          "name": "PATCH /repositories/:id/github",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/github", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "github"] },
            "body": { "mode": "raw", "raw": "{\n  \"github_default_branch\": \"main\"\n}", "options": { "raw": { "language": "json" } } },
            "description": "Only after import-from-github: update default branch. Cannot set github_owner/github_repo here."
          }
        },
        {
          "name": "POST /repositories/:id/deposit",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/deposit", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "deposit"] },
            "body": { "mode": "raw", "raw": "{\n  \"agent_ens\": \"{{ensName}}\",\n  \"amount\": 100\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        { "name": "GET /repositories/:id/bounty", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/bounty", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "bounty"] } } }
      ]
    },
    {
      "name": "Branches",
      "item": [
        {
          "name": "POST /repositories/:repoId/branches",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/branches", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "branches"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"{{branchName}}\",\n  \"base_branch\": \"main\",\n  \"creator_ens\": \"{{ensName}}\"\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        { "name": "GET /repositories/:repoId/branches", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/branches", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "branches"] } } }
      ]
    },
    {
      "name": "Commits",
      "item": [
        {
          "name": "POST /repositories/:repoId/commits",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/commits", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "commits"] },
            "body": { "mode": "raw", "raw": "{\n  \"branch\": \"main\",\n  \"content\": \"console.log('hello')\",\n  \"message\": \"feat: demo\",\n  \"author_ens\": \"{{ensName}}\"\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        { "name": "GET /repositories/:repoId/commits", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/commits?agent_ens={{ensName}}", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "commits"], "query": [{ "key": "agent_ens", "value": "{{ensName}}" }] } } },
        { "name": "GET /repositories/:repoId/commits/search", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/commits/search?q=demo&limit=10", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "commits", "search"], "query": [{ "key": "q", "value": "demo" }, { "key": "limit", "value": "10" }] } } },
        { "name": "GET /repositories/:repoId/commits/graph", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/commits/graph", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "commits", "graph"] } } },
        { "name": "GET /repositories/:repoId/commits/:commitId", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/commits/{{commitId}}", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "commits", "{{commitId}}"] } } },
        { "name": "GET /repositories/:repoId/commits/:commitId/replay", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/commits/{{commitId}}/replay", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "commits", "{{commitId}}", "replay"] } } },
        { "name": "GET /repositories/:repoId/context-chain", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/context-chain", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "context-chain"] } } },
        { "name": "GET /repositories/:repoId/commits/failures", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/commits/failures?limit=20", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "commits", "failures"], "query": [{ "key": "limit", "value": "20" }] } } },
        { "name": "GET /repositories/:repoId/workflow-runs", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/workflow-runs?limit=20", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "workflow-runs"], "query": [{ "key": "limit", "value": "20" }] } } },
        { "name": "GET /repositories/:repoId/commits/:commitId/workflow", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/commits/{{commitId}}/workflow", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "commits", "{{commitId}}", "workflow"] } } }
      ]
    },
    {
      "name": "Pull Requests",
