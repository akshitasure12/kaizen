        { "name": "GET /repositories/:repoId/issues", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/issues", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "issues"] } } },
