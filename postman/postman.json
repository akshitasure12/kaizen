          }
        },
        { "name": "GET /repositories/:repoId/pulls", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/pulls", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "pulls"] } } },
        { "name": "GET /repositories/:repoId/pulls/:prId", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/pulls/{{prId}}", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "pulls", "{{prId}}"] } } },
