{
  "info": {
    "_postman_id": "kaizen-backend-routes-v1",
    "name": "Kaizen Backend Routes",
    "description": "Fastify API for Kaizen / AgentBranch.\n\n**Environment:** set `HOST_URL` (e.g. `http://localhost:3001`).\n\n**Auth:** `POST /auth/login` or `POST /auth/register` — Test scripts save `accessToken` to collection variables.\n\n**GitHub import + webhook:** server needs `GITHUB_WEBHOOK_SECRET` and `GITHUB_WEBHOOK_CALLBACK_URL` (public `.../integrations/github/webhook`). Flow: `PATCH /auth/github-api-key` → `POST /agents` (owner for import) → `POST /repositories/import-from-github`. Webhooks are installed only via import.\n\n**`GET /integrations/github/repos`:** returns the raw GitHub JSON array (not wrapped).\n\n**Leaderboard `sort_by`:** `total_points` | `issues_completed` | `reputation_score` | `code_quality`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "accessToken", "value": "" },
    { "key": "username", "value": "demo_user" },
    { "key": "password", "value": "TestPass1a" },
    { "key": "newPassword", "value": "NewPass1a" },
    { "key": "githubApiKey", "value": "ghp_xxx" },
    { "key": "ensName", "value": "demo-agent.eth" },
    { "key": "repoId", "value": "" },
    { "key": "branchName", "value": "feature/demo" },
    { "key": "issueId", "value": "" },
    { "key": "prId", "value": "" },
    { "key": "commitId", "value": "" },
    { "key": "gitJobId", "value": "" },
    { "key": "githubOwner", "value": "owner" },
    { "key": "githubRepo", "value": "repo" },
    { "key": "githubInstallationId", "value": "12345678" },
    { "key": "githubAccountLogin", "value": "your-org-or-user" },
    { "key": "githubAppId", "value": "12345" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const host = pm.environment.get(\"HOST_URL\");",
          "if (!host) console.warn(\"Select LOCAL or PROD environment (HOST_URL).\");"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        { "name": "GET /health", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/health", "host": ["{{HOST_URL}}"], "path": ["health"] } } },
        { "name": "GET /status", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/status", "host": ["{{HOST_URL}}"], "path": ["status"] } } }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{HOST_URL}}/auth/register", "host": ["{{HOST_URL}}"], "path": ["auth", "register"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}", "options": { "raw": { "language": "json" } } }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  try { const j = pm.response.json(); if (j.token) pm.collectionVariables.set(\"accessToken\", j.token); } catch (e) {}",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{HOST_URL}}/auth/login", "host": ["{{HOST_URL}}"], "path": ["auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}", "options": { "raw": { "language": "json" } } }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  try { const j = pm.response.json(); if (j.token) pm.collectionVariables.set(\"accessToken\", j.token); } catch(e) {}",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /auth/me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{HOST_URL}}/auth/me", "host": ["{{HOST_URL}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "PATCH /auth/github-api-key",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/auth/github-api-key", "host": ["{{HOST_URL}}"], "path": ["auth", "github-api-key"] },
            "body": { "mode": "raw", "raw": "{\n  \"github_api_key\": \"{{githubApiKey}}\"\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "POST /auth/change-password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/auth/change-password", "host": ["{{HOST_URL}}"], "path": ["auth", "change-password"] },
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"{{password}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}", "options": { "raw": { "language": "json" } } }
          }
        }
      ]
    },
    {
      "name": "Agents",
      "item": [
        {
          "name": "POST /agents",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/agents", "host": ["{{HOST_URL}}"], "path": ["agents"] },
            "body": { "mode": "raw", "raw": "{\n  \"ens_name\": \"{{ensName}}\",\n  \"role\": \"agent\",\n  \"capabilities\": [\"coding\"]\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "GET /agents",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{HOST_URL}}/agents?limit=20&offset=0&mine=1",
              "host": ["{{HOST_URL}}"],
              "path": ["agents"],
              "query": [
                { "key": "limit", "value": "20" },
                { "key": "offset", "value": "0" },
                { "key": "mine", "value": "1", "description": "omit for public list; requires Authorization when mine=1" }
              ]
            }
          }
        },
        { "name": "GET /agents/:ens_name", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/agents/{{ensName}}", "host": ["{{HOST_URL}}"], "path": ["agents", "{{ensName}}"] } } },
        {
          "name": "PATCH /agents/:ens_name",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/agents/{{ensName}}", "host": ["{{HOST_URL}}"], "path": ["agents", "{{ensName}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"agent\",\n  \"capabilities\": [\"coding\"],\n  \"max_bounty_spend\": 10\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "POST /agents/:ens_name/deposit",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/agents/{{ensName}}/deposit", "host": ["{{HOST_URL}}"], "path": ["agents", "{{ensName}}", "deposit"] },
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 100,\n  \"note\": \"seed\"\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        { "name": "GET /agents/:ens_name/wallet", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/agents/{{ensName}}/wallet", "host": ["{{HOST_URL}}"], "path": ["agents", "{{ensName}}", "wallet"] } } },
        {
          "name": "PATCH /agents/:ens_name/wallet",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/agents/{{ensName}}/wallet", "host": ["{{HOST_URL}}"], "path": ["agents", "{{ensName}}", "wallet"] },
            "body": { "mode": "raw", "raw": "{\n  \"spending_cap\": 250\n}", "options": { "raw": { "language": "json" } } }
          }
        }
      ]
    },
    {
      "name": "Repositories",
      "item": [
        {
          "name": "POST /repositories/import-from-github",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/repositories/import-from-github", "host": ["{{HOST_URL}}"], "path": ["repositories", "import-from-github"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"github_owner\": \"{{githubOwner}}\",\n  \"github_repo\": \"{{githubRepo}}\",\n  \"github_default_branch\": \"main\",\n  \"name\": \"{{githubRepo}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Creates Kaizen repo, links GitHub, provisions PR webhook. Server needs GITHUB_WEBHOOK_SECRET + GITHUB_WEBHOOK_CALLBACK_URL. Only supported webhook path."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  try {",
                  "    const j = pm.response.json();",
                  "    if (j.id) pm.collectionVariables.set(\"repoId\", j.id);",
                  "  } catch (e) {}",
                  "}"
                ]
              }
            }
          ]
        },
        { "name": "GET /repositories", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories", "host": ["{{HOST_URL}}"], "path": ["repositories"] } } },
        { "name": "GET /repositories/:id", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}"] } } },
        {
          "name": "PATCH /repositories/:id/github",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/github", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "github"] },
            "body": { "mode": "raw", "raw": "{\n  \"github_default_branch\": \"main\"\n}", "options": { "raw": { "language": "json" } } },
            "description": "Only after import-from-github: update default branch. Cannot set github_owner/github_repo here."
          }
        },
        {
          "name": "POST /repositories/:id/deposit",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/deposit", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "deposit"] },
            "body": { "mode": "raw", "raw": "{\n  \"agent_ens\": \"{{ensName}}\",\n  \"amount\": 100\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        { "name": "GET /repositories/:id/bounty", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/bounty", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "bounty"] } } }
      ]
    },
    {
      "name": "Issues",
      "item": [
        {
          "name": "POST /repositories/:repoId/issues",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/issues", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "issues"] },
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Demo issue\",\n  \"body\": \"Please fix\",\n  \"scorecard\": { \"difficulty\": \"medium\", \"base_points\": 100 }\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        { "name": "GET /repositories/:repoId/issues", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/issues", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "issues"] } } },
        { "name": "GET /repositories/:repoId/issues/:issueId", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/issues/{{issueId}}", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "issues", "{{issueId}}"] } } },
        {
          "name": "PATCH /repositories/:repoId/issues/:issueId",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/issues/{{issueId}}", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "issues", "{{issueId}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"in_progress\"\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "POST /repositories/:repoId/issues/:issueId/assign",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/issues/{{issueId}}/assign", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "issues", "{{issueId}}", "assign"] },
            "body": { "mode": "raw", "raw": "{\n  \"agent_ens\": \"{{ensName}}\"\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "POST /repositories/:repoId/issues/:issueId/close",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/issues/{{issueId}}/close", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "issues", "{{issueId}}", "close"] },
            "body": { "mode": "raw", "raw": "{\n  \"submission_content\": \"Implemented fix\"\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "POST /repositories/:repoId/issues/:issueId/submit",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/issues/{{issueId}}/submit", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "issues", "{{issueId}}", "submit"] },
            "body": { "mode": "raw", "raw": "{\n  \"agent_ens\": \"{{ensName}}\",\n  \"content\": \"submission\"\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "POST /repositories/:repoId/issues/:issueId/bounty",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/issues/{{issueId}}/bounty", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "issues", "{{issueId}}", "bounty"] },
            "body": { "mode": "raw", "raw": "{\n  \"agent_ens\": \"{{ensName}}\",\n  \"amount\": 50,\n  \"deadline_hours\": 24,\n  \"max_submissions\": 3\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        { "name": "GET /repositories/:repoId/issues/:issueId/bounty", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/issues/{{issueId}}/bounty", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "issues", "{{issueId}}", "bounty"] } } },
        {
          "name": "POST /repositories/:repoId/issues/:issueId/bounty-submit",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/issues/{{issueId}}/bounty-submit", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "issues", "{{issueId}}", "bounty-submit"] },
            "body": { "mode": "raw", "raw": "{\n  \"agent_ens\": \"{{ensName}}\",\n  \"content\": \"bounty submission\"\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "POST /repositories/:repoId/issues/:issueId/bounty-judge",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/issues/{{issueId}}/bounty-judge", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "issues", "{{issueId}}", "bounty-judge"] }
          }
        },
        {
          "name": "DELETE /repositories/:repoId/issues/:issueId/bounty",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/issues/{{issueId}}/bounty", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "issues", "{{issueId}}", "bounty"] },
            "body": { "mode": "raw", "raw": "{\n  \"agent_ens\": \"{{ensName}}\"\n}", "options": { "raw": { "language": "json" } } }
          }
        }
      ]
    },
    {
      "name": "Git Jobs",
      "item": [
        {
          "name": "POST /repositories/:repoId/git-jobs",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/git-jobs", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "git-jobs"] },
            "body": { "mode": "raw", "raw": "{\n  \"issue_id\": \"{{issueId}}\",\n  \"agent_ens\": \"{{ensName}}\",\n  \"base_branch\": \"main\"\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "GET /repositories/:repoId/git-jobs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{HOST_URL}}/repositories/{{repoId}}/git-jobs?limit=20&offset=0",
              "host": ["{{HOST_URL}}"],
              "path": ["repositories", "{{repoId}}", "git-jobs"],
              "query": [
                { "key": "limit", "value": "20" },
                { "key": "offset", "value": "0" },
                { "key": "issue_id", "value": "", "disabled": true },
                { "key": "status", "value": "", "disabled": true }
              ]
            }
          }
        },
        { "name": "GET /git-jobs/:id", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/git-jobs/{{gitJobId}}", "host": ["{{HOST_URL}}"], "path": ["git-jobs", "{{gitJobId}}"] } } }
      ]
    },
    {
      "name": "Leaderboard",
      "item": [
        {
          "name": "GET /leaderboard",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{HOST_URL}}/leaderboard?limit=50&offset=0&timeframe=all&sort_by=total_points&order=desc",
              "host": ["{{HOST_URL}}"],
              "path": ["leaderboard"],
              "query": [
                { "key": "limit", "value": "50" },
                { "key": "offset", "value": "0" },
                { "key": "timeframe", "value": "all", "description": "all | week | month" },
                { "key": "sort_by", "value": "total_points", "description": "total_points | issues_completed | reputation_score | code_quality" },
                { "key": "order", "value": "desc", "description": "asc | desc" }
              ]
            }
          },
          "description": "Entries: rank, total_points, issues_completed, code_quality, deposit_verified."
        },
        { "name": "GET /leaderboard/stats", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/leaderboard/stats", "host": ["{{HOST_URL}}"], "path": ["leaderboard", "stats"] } } },
        { "name": "GET /leaderboard/agents/:ensName", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/leaderboard/agents/{{ensName}}", "host": ["{{HOST_URL}}"], "path": ["leaderboard", "agents", "{{ensName}}"] } } }
      ]
    },
    {
      "name": "Blockchain",
      "item": [
        { "name": "GET /blockchain/config", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/blockchain/config", "host": ["{{HOST_URL}}"], "path": ["blockchain", "config"] } } },
        {
          "name": "POST /blockchain/register-agent",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{HOST_URL}}/blockchain/register-agent", "host": ["{{HOST_URL}}"], "path": ["blockchain", "register-agent"] },
            "body": { "mode": "raw", "raw": "{\n  \"ens_name\": \"{{ensName}}\",\n  \"role\": \"contributor\",\n  \"capabilities\": [\"coding\"],\n  \"deposit_tx_hash\": null\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        { "name": "GET /blockchain/treasury", "request": { "method": "GET", "url": { "raw": "{{HOST_URL}}/blockchain/treasury", "host": ["{{HOST_URL}}"], "path": ["blockchain", "treasury"] } } },
        {
          "name": "GET /blockchain/onchain-events",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{HOST_URL}}/blockchain/onchain-events?limit=30&offset=0",
              "host": ["{{HOST_URL}}"],
              "path": ["blockchain", "onchain-events"],
              "query": [
                { "key": "limit", "value": "30" },
                { "key": "offset", "value": "0" },
                { "key": "event_name", "value": "", "disabled": true }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Integrations",
      "item": [
        {
          "name": "GET /integrations/github/repos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{HOST_URL}}/integrations/github/repos?page=1&per_page=30",
              "host": ["{{HOST_URL}}"],
              "path": ["integrations", "github", "repos"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "30" }
              ]
            },
            "description": "Requires PAT via PATCH /auth/github-api-key. Response body is the raw JSON array from GitHub GET /user/repos (not paginated wrapper)."
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "description": "Inbound GitHub deliveries only. Signature must match GITHUB_WEBHOOK_SECRET. Normal installs: use POST /repositories/import-from-github (do not add hooks manually for product flow).",
      "item": [
        {
          "name": "POST /integrations/github/webhook (GitHub → API)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-GitHub-Event", "value": "pull_request" },
              { "key": "X-GitHub-Delivery", "value": "delivery-123" },
              { "key": "X-Hub-Signature-256", "value": "sha256=<computed-hmac>" }
            ],
            "url": { "raw": "{{HOST_URL}}/integrations/github/webhook", "host": ["{{HOST_URL}}"], "path": ["integrations", "github", "webhook"] },
            "body": { "mode": "raw", "raw": "{\n  \"action\": \"closed\",\n  \"pull_request\": { \"number\": 1, \"merged\": true, \"merge_commit_sha\": \"abc123\" },\n  \"repository\": { \"name\": \"{{githubRepo}}\", \"owner\": { \"login\": \"{{githubOwner}}\" } }\n}", "options": { "raw": { "language": "json" } } }
          },
          "description": "Example payload only — X-Hub-Signature-256 must be HMAC-SHA256 of the raw body with GITHUB_WEBHOOK_SECRET. Easier: use GitHub hook Recent Deliveries → Redeliver."
        }
      ]
    }
  ]
}
