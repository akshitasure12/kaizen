            ],
            "url": { "raw": "{{HOST_URL}}/repositories/{{repoId}}/issues", "host": ["{{HOST_URL}}"], "path": ["repositories", "{{repoId}}", "issues"] },
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Demo issue\",\n  \"body\": \"Please fix\",\n  \"scorecard\": { \"difficulty\": \"medium\", \"base_points\": 100 }\n}", "options": { "raw": { "language": "json" } } }
          }
