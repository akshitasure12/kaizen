# Copy to .env at repo root (loaded by API, worker, and Next.js via next.config).

NODE_ENV=development

# API (Fastify)
HOST=0.0.0.0
PORT=3001

# Postgres (docker-compose default matches this)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Auth — use a long random string in production (plan: non-default JWT_SECRET)
JWT_SECRET=change-me-to-a-long-random-secret-in-production

# Gemini API key (free tier supported via AI Studio)
GEMINI_API_KEY=

# Gemini model tiers (April 2026 free-tier defaults)
GEMINI_MODEL_FAST=gemini-3.1-flash-lite-preview
GEMINI_MODEL_BALANCED=gemini-3-flash-preview
GEMINI_MODEL_COMPLEX=gemini-2.5-pro

# Embeddings model
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Thinking budgets for Gemini 2.5 models (tokens)
# low: quick checks, medium: standard judge pass, high: hard/expert tasks
GEMINI_THINKING_BUDGET_LOW=0
GEMINI_THINKING_BUDGET_MEDIUM=512
GEMINI_THINKING_BUDGET_HIGH=2048

# Per-user GitHub PAT: PATCH /auth/github-api-key (stored on users.github_api_key).
# Webhook HMAC for POST /integrations/github/webhook:
GITHUB_WEBHOOK_SECRET=
# Full public URL GitHub should call (path must be /integrations/github/webhook). Required for
# POST /repositories/import-from-github (dashboard import). Example with ngrok:
# GITHUB_WEBHOOK_CALLBACK_URL=https://abc123.ngrok-free.app/integrations/github/webhook
GITHUB_WEBHOOK_CALLBACK_URL=

# ngrok — only for docker-compose `tunnel` profile (https://dashboard.ngrok.com → authtoken)
# NGROK_AUTHTOKEN=

# CORS: comma-separated origins, or * for dev (plan: restrict in production)
CORS_ORIGIN=*

# Temp dir for git clones (default: os.tmpdir()/kaizen-git-jobs)
# GIT_TMP_ROOT=/var/tmp/kaizen-git

# Frontend → API (browser)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Worker (DB-backed git_jobs poll)
WORKER_POLL_MS=5000
WORKER_CONCURRENCY=1
WORKER_LEASE_TIMEOUT_MS=60000
WORKER_MAX_ATTEMPTS=3
WORKER_BASE_RETRY_MS=5000
WORKER_MAX_RETRY_MS=60000
# WORKER_INSTANCE_ID=local-dev-worker
# WORKER_DRY_RUN=false

# Merge-gated payout curve (score normalized to [0,1])
PAYOUT_SCORE_FLOOR=0.40
PAYOUT_MIN_ABOVE_FLOOR=0.25
PAYOUT_EXPONENT=1.2

# Agent incentive updates (EWMA reputation)
REPUTATION_EWMA_ALPHA=0.20
REPUTATION_NO_MERGE_PENALTY=0.05

# Base Sepolia — agent deposit verification (AgentBranchToken.depositForAgent)
# Deploy from ./contracts: forge script script/Deploy.s.sol --rpc-url $BASE_SEPOLIA_RPC_URL --broadcast
# Then set addresses below.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
PRIVATE_KEY=0x...                     # deployer private key for contract deployment
ABT_CONTRACT_ADDRESS=0x...            # deployed AgentBranchToken contract address
BOUNTY_CONTRACT_ADDRESS=0x...         # deployed BountyPayment contract address
TREASURY_ADDRESS=0x...                # treasury address used during deployment

NEXT_PUBLIC_ABT_CONTRACT_ADDRESS=0x...
NEXT_PUBLIC_BOUNTY_CONTRACT_ADDRESS=0x...
NEXT_PUBLIC_CHAIN_ID=...

# Optional: internal service auth for future write-heavy routes
# INTERNAL_SERVICE_SECRET=