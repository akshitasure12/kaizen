# Copy to .env at repo root (loaded by API, worker, and Next.js via next.config).

NODE_ENV=development

# API (Fastify)
HOST=0.0.0.0
PORT=3001

# Postgres (docker-compose default matches this)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Auth — use a long random string in production (plan: non-default JWT_SECRET)
JWT_SECRET=change-me-to-a-long-random-secret-in-production

# LLM / judge / embeddings (optional until wired)
OPENAI_API_KEY=

# Per-user GitHub PAT: PATCH /auth/github-api-key (stored on users.github_api_key).
# Webhook HMAC for POST /integrations/github/webhook:
GITHUB_WEBHOOK_SECRET=

# CORS: comma-separated origins, or * for dev (plan: restrict in production)
CORS_ORIGIN=*

# Temp dir for git clones (default: os.tmpdir()/kaizen-git-jobs)
# GIT_TMP_ROOT=/var/tmp/kaizen-git

# Frontend → API (browser)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Worker (DB-backed git_jobs poll)
WORKER_POLL_MS=5000

# Base Sepolia — agent deposit verification (AgentBranchToken.depositForAgent)
# Deploy from ./contracts: forge script script/Deploy.s.sol --rpc-url $BASE_SEPOLIA_RPC_URL --broadcast
# Then set addresses below.
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# ABT_CONTRACT_ADDRESS=0x...
# BOUNTY_CONTRACT_ADDRESS=0x...
# TREASURY_ADDRESS=0x...

# Optional: internal service auth for future write-heavy routes
# INTERNAL_SERVICE_SECRET=
