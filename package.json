{
  "name": "kaizen",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.2.5",
  "workspaces": [
    "backend",
    "frontend",
    "worker"
  ],
  "scripts": {
    "dev": "bun run dev:api",
    "dev:api": "bun run --cwd backend dev",
    "dev:frontend": "bun run --cwd frontend dev",
    "dev:worker": "bun run --cwd backend worker",
    "build": "bun run --cwd backend build && bun run --cwd frontend build",
    "build:backend": "bun run --cwd backend build",
    "build:frontend": "bun run --cwd frontend build",
    "start:api": "bun run --cwd backend start",
    "start:worker": "bun run --cwd backend worker",
    "start:frontend": "bun run --cwd frontend start",
    "migrate": "bun run --cwd backend migrate",
    "compose:up": "docker compose up -d postgres",
    "compose:down": "docker compose down",
    "tunnel:ngrok": "ngrok http 3001"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "fastify-raw-body": "^5.0.0"
  }
}
